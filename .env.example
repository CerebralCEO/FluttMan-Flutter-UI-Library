# FlutMan Flutter UI Library - Environment Variables
# Copy this file to .env and fill in your actual values

# ==========================================
# Supabase Configuration
# ==========================================
# Get these from your Supabase project dashboard: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key - ONLY for server-side operations (GitHub Actions, API routes)
# NEVER expose this in client-side code or commit to public repos
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==========================================
# Optional: Analytics & Monitoring
# ==========================================
# NEXT_PUBLIC_ANALYTICS_ID=

# ==========================================
# Optional: Deployment
# ==========================================
# NETLIFY_SITE_ID=
# NETLIFY_AUTH_TOKEN=
